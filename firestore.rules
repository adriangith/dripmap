rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Each user can only read/write their own document
    match /users/{uid} {
      allow read, write: if request.auth != null && request.auth.uid == uid;
    }

    // Public read access for location data
    match /locations/{slug} {
      allow read: if true;
    }

    // Public read access for metadata (e.g. data version hash)
    match /meta/{docId} {
      allow read: if true;
    }
  }
}
